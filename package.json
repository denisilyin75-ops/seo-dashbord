{
  "name": "seo-command-center",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "description": "SEO/Affiliate portfolio command center — dashboard, AI commands, WordPress/GA4/GSC integrations, deploy wizard.",
  "scripts": {
    "dev": "concurrently -n vite,api -c blue,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "nodemon --watch server server/index.js",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "seed": "node server/scripts/seed.js",
    "install-hooks": "node server/scripts/install-hooks.js",
    "code-review": "node server/scripts/code-review.js --trigger=manual --sha=HEAD",
    "test": "node --test --test-reporter=spec server/services/__tests__"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google-analytics/data": "^4.12.0",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "googleapis": "^144.0.0",
    "@mozilla/readability": "^0.5.0",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.453.0",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.3",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10"
  }
}
