# Preset для popolkam.ru — эталонный сайт SEO-портфеля (RU, кофе/бытовая техника)
# Запуск:
#   scp -r server/scripts/wp-provision root@5.129.245.98:/tmp/
#   ssh root@5.129.245.98 "cd /tmp/wp-provision && source presets/popolkam.env && bash provision-site.sh"

export DOMAIN="popolkam.ru"
export SITE_SLUG="popolkam"
export SITE_TITLE="Popolkam — Бытовая техника по полочкам"
export SITE_DESCRIPTION="Обзоры, сравнения и рейтинги бытовой техники для дома. Всё по полочкам."
export ADMIN_USER="admin_pp"
# При первой установке пароль будет сгенерирован если не задать. После — значение игнорируется.
# export ADMIN_PASS="..."
export ADMIN_EMAIL="denis.ilyin75@gmail.com"

export LOCALE="ru_RU"
export TIMEZONE="Europe/Moscow"

# Границы ниши popolkam.ru (см. memory/project_content_strategy.md):
# БТ для дома — кухня + уборка + стирка + климат.
export CATEGORIES="Кофемашины|slug=kofemashiny|desc=Рожковые, капсульные, автоматические. Обзоры и сравнения.;Кухонная техника|slug=kuhnya|desc=Блендеры, мультиварки, СВЧ, посудомойки, чайники.;Уборка|slug=uborka|desc=Роботы-пылесосы, моющие, паровые швабры.;Климат и уход|slug=klimat|desc=Кондиционеры, увлажнители, фены, стайлеры.;Стирка|slug=stirka|desc=Стиральные и сушильные машины."

# Плагины (бесплатные из .org). REHub и Content Egg — платные, ставятся отдельно.
export PLUGINS="seo-by-rank-math woocommerce wordpress-importer"

export HOMEPAGE_TITLE="Popolkam — Бытовая техника по полочкам"
export HOMEPAGE_CONTENT="Обзоры, сравнения и рейтинги бытовой техники для дома. Всё по полочкам."
