# Preset для «Ай как чисто!» — RU-контент про уборку дома + бытовую химию
# Автор-аватар: Дарья Метёлкина (вымышленный персонаж, редакционный образ)
# Референс: ohsospotless.com (улучшенный ремейк под русский рынок)
#
# Статус домена: AYKAKCHISTO.RU ПОКА НЕ КУПЛЕН.
# Временный доступ через субдомен aykakchisto.bonaka.app — указать в Traefik labels
# docker-compose.yml. Когда купишь реальный домен — просто swap Host-правило.
#
# Запуск:
#   scp -r server/scripts/wp-provision root@5.129.245.98:/tmp/
#   ssh root@5.129.245.98 "cd /tmp/wp-provision && \
#     source presets/aykakchisto.env && \
#     bash provision-site.sh && \
#     bash polish-site.sh"

# ВНИМАНИЕ: DOMAIN пока указываем как временный субдомен, потом заменим
export DOMAIN="aykakchisto.bonaka.app"
export SITE_SLUG="aykakchisto"
export SITE_TITLE="Ай как чисто! — Справочник по чистоте в доме"
export SITE_DESCRIPTION="Решения трудных случаев: пятна, запахи, налёт, плесень, техника. Без фанатизма, без магии — только проверенные методы. Ведёт Дарья Метёлкина, химик по образованию."

export ADMIN_USER="admin_ayka"
# ADMIN_PASS сгенерируется автоматически при первой установке, запишется в stdout
export ADMIN_EMAIL="denis.ilyin75@gmail.com"

export LOCALE="ru_RU"
export TIMEZONE="Europe/Moscow"

# Для polish-site.sh (E-E-A-T страницы + brand)
export AUTHOR_NAME="Дарья Метёлкина"
export BRAND_TAGLINE="«Ай как чисто!» — справочник по чистоте в доме. Трудные случаи (пятна, запахи, налёт, плесень), обзоры техники и средств. Принцип паритета: народные методы и промышленная химия рядом, честно о каждом."

# 12 основных рубрик (§4.3 брифа). Порядок важен — первые 6 пойдут в главное меню,
# остальные в footer/sidebar. polish-site.sh может это учесть.
export CATEGORIES="\
Пятна и следы|slug=pyatna|desc=Трудные случаи на ткани, мебели, полах. Винное, жирное, от ягод, от травы, от краски.;\
Запахи|slug=zapahi|desc=Источники, устранение, профилактика. От холодильника, кошачьей мочи, сырости, гари.;\
Кухня|slug=kuhnya|desc=Плита, духовка, вытяжка, посуда, посудомойка, холодильник.;\
Ванная и санузел|slug=vannaya|desc=Налёт, засечка, плесень, сантехника, запах из слива.;\
Полы|slug=poly|desc=Ламинат, паркет, плитка, линолеум, ковры.;\
Техника для уборки|slug=tehnika|desc=Пылесосы, пароочистители, мойки окон, роботы.;\
Стирка и ткани|slug=stirka|desc=Машина, средства, режимы, деликатные ткани.;\
Воздух и микроклимат|slug=vozduh|desc=Увлажнители, очистители, плесень, пыль, аллергены.;\
Дача и загородный дом|slug=dacha|desc=Колодец, баня, погреб, мангал, терраса.;\
Сезонные уборки|slug=sezon|desc=Весенняя, предновогодняя, после ремонта, после гостей.;\
С животными и детьми|slug=pitomcy-deti|desc=Шерсть, метки, пластилин, слаймы, поломастер.;\
Организация|slug=organizaciya|desc=Системы хранения как дополнение к уборке (не самоцель)."

# Плагины (бесплатные). Rank Math для SEO, cyr2lat для транслита slug'ов.
# REHub — наш платный, установим руками через Envato.
export PLUGINS="seo-by-rank-math wordpress-importer cyr2lat"

# Главная страница — минимум на старте, доработаем после Gutenberg-блоков
export HOMEPAGE_TITLE="Ай как чисто! — справочник по чистоте в доме"
export HOMEPAGE_CONTENT="Решения трудных случаев без фанатизма и без магии. От выведения пятен до выбора пылесоса, с честной проверкой народных методов и промышленных средств. Ведёт Дарья Метёлкина, химик по образованию."
export BLOG_PAGE_TITLE="Все материалы"
export BLOG_PAGE_SLUG="materialy"
export MENU_NAME="Главное меню"

# ================================================================
# ЗАМЕТКИ ДЛЯ ПОСЛЕДУЮЩИХ ШАГОВ:
# ================================================================
# 1. После provision-site.sh:
#    - Поменять wp-admin пароль на что-то запоминающееся (сохранить в памяти SCC)
#    - Установить REHub вручную (у нас уже есть лицензия) или оставить стандартную тему
#    - Активировать Rank Math wizard
#    - Сгенерировать Application Password для SCC (WP-admin → Users → Profile)
# 2. После polish-site.sh:
#    - E-E-A-T: о Дарье (развёрнутая страница с дисклеймером о редакционном образе)
#    - Контакты, Политика конфиденциальности, Как мы тестируем
# 3. Добавить в SCC как site: status=setup, niche="Бытовая химия / уборка"
# 4. Купить домен aykakchisto.ru — сменить DOMAIN и Traefik labels в compose
# 5. Дизайн-ревью палитры (§10.2 брифа): тёмно-синий #1E3A5F + оранжевый #E8A04C
#    — к REHub adapter'у когда будет стек готов.
