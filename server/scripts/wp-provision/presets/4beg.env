# Preset для 4beg.ru — обзоры беговых кроссовок (RU)
# Используется для будущей миграции с Timeweb на наш сервер (5.129.245.98)
# Сейчас сайт работает на Timeweb; preset готов для запуска provision-site.sh + polish-site.sh
# когда получим доступы (SSH/БД/uploads).
#
# Запуск (после получения БД dump от Timeweb):
#   scp -r server/scripts/wp-provision root@5.129.245.98:/tmp/
#   ssh root@5.129.245.98 "cd /tmp/wp-provision && \
#     source presets/4beg.env && \
#     bash provision-site.sh && \
#     # Здесь — импорт дампа БД + uploads
#     bash polish-site.sh"

export DOMAIN="4beg.ru"
export SITE_SLUG="4beg"
export SITE_TITLE="4beg.ru — Обзоры беговых кроссовок"
export SITE_DESCRIPTION="Независимые обзоры, сравнения и рейтинги беговых кроссовок. Помогаем выбрать под ваш стиль бега, тип пронации и бюджет."

export ADMIN_USER="admin_4beg"
export ADMIN_EMAIL="denis.ilyin75@gmail.com"

export LOCALE="ru_RU"
export TIMEZONE="Europe/Moscow"

# Для polish-site.sh
export AUTHOR_NAME="Редакция 4beg"
export BRAND_TAGLINE="4beg.ru — независимые обзоры беговых кроссовок. Разбираем модели Asics, Nike, Adidas, Saucony, New Balance, Hoka и других по параметрам, которые реально важны для бегуна: пронация, амортизация, вес, дроп."

# Текущие категории 4beg (по факту WP REST на 2026-04-18).
# При миграции БД эти категории уже будут в импортируемых данных — оставляем как есть.
# provision-site.sh не будет их создавать повторно (идемпотентность).
# Если запускаем preset на ЧИСТОМ сайте (не миграция) — используем эти категории:
export CATEGORIES="Обувь для бега|slug=obuv-dlya-bega|desc=Главная категория: обзоры всех беговых кроссовок — от бюджетных до профессиональных.;Asics|slug=asics|desc=Обзоры беговых кроссовок Asics: Gel-Kayano, Gel-Nimbus, Gel-Cumulus, GT-2000 и других линеек.;Nike|slug=nike|desc=Обзоры беговых кроссовок Nike: Pegasus, Vaporfly, Alphafly, Zoom, ZoomX Invincible, Structure и другие.;Adidas|slug=adidas|desc=Обзоры беговых кроссовок Adidas: Adizero, Ultraboost, Supernova, Boston, Prime и другие серии.;Saucony|slug=saucony|desc=Обзоры беговых кроссовок Saucony: Triumph, Kinvara, Endorphin, Guide, Ride и других.;New Balance|slug=new-balance|desc=Обзоры беговых кроссовок New Balance: Fresh Foam, FuelCell, серия 1080, 880, 860 и других.;Hoka One One|slug=hoka-one-one|desc=Обзоры беговых кроссовок Hoka: Clifton, Bondi, Mach, Speedgoat, Rincon и других.;Гайды|slug=gajd-po-vyboru-obuvi|desc=Руководства по выбору беговой обуви: пронация, дроп, типы покрытий, замена обуви."

# Плагины (бесплатные). REHub + Rank Math уже на Timeweb — после миграции сохраняются.
export PLUGINS="seo-by-rank-math wordpress-importer cyr2lat"

# Содержимое главной при fresh-setup. При миграции БД перезатрёт.
export HOMEPAGE_TITLE="4beg — Обзоры беговых кроссовок"
export HOMEPAGE_CONTENT="Независимые обзоры, сравнения и рейтинги беговых кроссовок для любого стиля бега."
export BLOG_PAGE_TITLE="Все обзоры"
export BLOG_PAGE_SLUG="obzory"
export MENU_NAME="Главное меню"

# ================================================================
# МИГРАЦИОННЫЕ ЗАМЕТКИ (для будущего):
# ================================================================
# 1. На Timeweb сайт 4beg уже работает на WP + REHub + Rank Math
# 2. При миграции:
#    a. Запустить provision-site.sh (создаст контейнер wp-4beg + пустой WP)
#    b. Импортировать БД dump (mysql import)
#    c. Скопировать /wp-content/uploads/ (rsync)
#    d. Обновить site_url и home_url на "https://4beg.ru" (если нужно)
#    e. wp cache flush, wp rewrite flush
#    f. DNS смена: 4beg.ru → 5.129.245.98 (Traefik выпустит SSL)
#    g. Проверить все URL, активные redirect'ы
# 3. После миграции - НЕ запускать polish-site.sh в default режиме
#    (перезапишет существующий контент). Использовать только шаги
#    которые не пересекаются (например, mu-plugin allow-svg, PHP limits).
