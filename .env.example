PORT=3001
NODE_ENV=production

# ---- Авторизация ----
# Пусто = без авторизации (dev). Для production установить длинный random string.
AUTH_TOKEN=

# ---- AI Provider ----
# Три варианта: local | openrouter | anthropic
# Если не указан — автовыбор: local (при наличии LOCAL_LLM_URL), затем openrouter, затем anthropic.
AI_PROVIDER=openrouter

# Anthropic API напрямую (https://console.anthropic.com):
ANTHROPIC_API_KEY=

# OpenRouter (https://openrouter.ai/keys) — OpenAI-совместимый, дешевле,
# поддерживает кучу моделей:
OPENROUTER_API_KEY=sk-or-v1-...
# Опционально: URL сайта для OpenRouter analytics
OPENROUTER_REFERER=https://cmd.bonaka.app

# Local LLM (Ollama, vLLM, LM Studio и пр. — OpenAI-совместимый или Ollama API).
# Если LOCAL_LLM_URL задан, местный LLM станет primary для bulk задач (content-quality,
# article-actions с типом 'structural_analysis'/'fact_extraction'), fallback на cloud.
# Для публикационного контента (rewrite_voice, merge) продолжаем использовать cloud Sonnet.
#
# Настройка через Tailscale VPN:
#   1. Установить Ollama на домашний сервер (ollama serve)
#   2. Tailscale share — получить IP типа 100.x.y.z
#   3. LOCAL_LLM_URL=http://100.x.y.z:11434 (Ollama default port)
#   4. LOCAL_LLM_MODEL=qwen2.5:72b (или llama3.1:70b, или любая подтянутая)
# LOCAL_LLM_URL=http://100.100.100.100:11434
# LOCAL_LLM_MODEL=qwen2.5:72b
# LOCAL_LLM_API_TYPE=ollama       # ollama (default) | openai (для vLLM/LM Studio)

# Модель (опционально, дефолты в коде):
#   anthropic:  claude-sonnet-4-20250514
#   openrouter: anthropic/claude-sonnet-4
#   local:      qwen2.5:72b
# Альтернативы на OpenRouter:
#   anthropic/claude-haiku-4.5       — быстро и дёшево для bulk
#   anthropic/claude-sonnet-4.6     — quality publication content
#   anthropic/claude-opus-4         — мощнее, дороже
AI_MODEL=

# ---- Google (Service Account) ----
# Один из двух способов:
GOOGLE_APPLICATION_CREDENTIALS=./google-sa-key.json
# или inline (экранировать переводы строк через \n):
# GOOGLE_CLIENT_EMAIL=sa@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."

# ---- n8n ----
N8N_WEBHOOK_BASE=https://n8n.your-server.com/webhook

# ---- Default WordPress (для deploy) ----
WP_DEFAULT_ADMIN_EMAIL=admin@bonaka.app
SERVER_SSH_HOST=5.129.245.98
SERVER_SSH_USER=deploy
SERVER_SSH_KEY_PATH=~/.ssh/deploy_key

# ---- SQLite ----
DB_PATH=./data/seo.sqlite

# ---- Cron ----
# Установить в 1 чтобы отключить встроенный cron (если используете n8n)
DISABLE_CRON=
